<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory
        android:layout="@layout/mtrl_pref_category"
        android:title="@string/listview_category">
        <ListPreference
            android:entries="@array/listanimation_entry"
            android:layout="@layout/mtrl_pref_item"
            android:title="@string/listview"
            android:key="key_chat_animation"
            android:summary="%s"
            android:defaultValue="0"
            android:entryValues="@array/listanimation_value"/>
    </PreferenceCategory>
    <ListPreference
        android:entries="@array/animation_name"
        android:layout="@layout/mtrl_pref_item"
        android:title="Change Animation in Splash"
        android:key="animation_key"
        android:summary="%s"
        android:defaultValue="0"
        android:entryValues="@array/animation_number"/>
    <PreferenceCategory
        android:layout="@layout/mtrl_pref_category"
        android:title="Wave Animation">
        <SwitchPreference
            android:layout="@layout/mtrl_pref_item"
            android:title="@string/show_wave"
            android:key="wave_start"
            android:defaultValue="false"/>
        <com.rull.mod.SeekBarPreference
            android:max="100"
            android:title="@string/wave_level"
            android:key="wave_level"
            android:defaultValue="30"/>
        <com.rull.mod.color.ColorPickerPreference
            android:layout="@layout/mtrl_pref_item"
            android:title="@string/wave_color"
            android:key="wave_color"
            android:summary=""
            android:defaultValue="0x543ae6f5"
            alphaSlider="true"
            hexValue="true"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/mtrl_pref_category"
        android:title="@string/others">
        <Preference
            android:layout="@layout/mtrl_pref_item"
            android:title="@string/save_setting"
            android:key="save_temp"
            android:summary="@string/save_setting_summary"/>
        <Preference
            android:layout="@layout/mtrl_pref_item"
            android:title="@string/load_setting"
            android:key="load_pref_file"
            android:summary="@string/load_setting_summary"/>
        <Preference
            android:layout="@layout/mtrl_pref_item"
            android:title="@string/reset_setting"
            android:key="clear_pref_file"
            android:summary="@string/reset_setting_summary"/>
    </PreferenceCategory>
</PreferenceScreen>
