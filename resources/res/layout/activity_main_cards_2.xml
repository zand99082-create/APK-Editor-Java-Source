<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <HorizontalScrollView
                android:orientation="horizontal"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:scrollbars="none"
                android:drawingCacheQuality="high"
                android:clipToPadding="false"
                android:animationCache="true"
                android:alwaysDrawnWithCache="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:smoothScrollbar="true">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_apk"
                            android:focusable="true"
                            android:clickable="true"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:layout_marginLeft="8dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:checkable="true"
                            app:cardBackgroundColor="?attr/card1"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                style="@style/MD.B"/>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="16dp"
                                android:layout_marginRight="16dp">
                                <TextView
                                    android:textStyle="bold"
                                    android:ellipsize="end"
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="@string/action_apk"
                                    android:maxLines="2"
                                    style="@style/MD.C"/>
                                <TextView
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:text="@string/action_apk_desc"
                                    style="@style/MD.D"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_app"
                            android:focusable="true"
                            android:clickable="true"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:layout_marginLeft="8dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:checkable="true"
                            app:cardBackgroundColor="?attr/card2"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                style="@style/MD.B"/>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="16dp"
                                android:layout_marginRight="16dp">
                                <TextView
                                    android:textStyle="bold"
                                    android:ellipsize="end"
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="@string/action_app"
                                    android:maxLines="2"
                                    style="@style/MD.C"/>
                                <TextView
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:text="@string/action_app_desc"
                                    style="@style/MD.D"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_sign"
                            android:focusable="true"
                            android:clickable="true"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:layout_marginLeft="8dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:checkable="true"
                            app:cardBackgroundColor="?attr/card5"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                style="@style/MD.B"/>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="16dp"
                                android:layout_marginRight="16dp">
                                <TextView
                                    android:textStyle="bold"
                                    android:ellipsize="end"
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="@string/action_sign"
                                    android:maxLines="2"
                                    style="@style/MD.C"/>
                                <TextView
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:text="@string/action_sign_desc"
                                    style="@style/MD.D"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_verify"
                            android:focusable="true"
                            android:clickable="true"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:layout_marginLeft="8dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:checkable="true"
                            app:cardBackgroundColor="?attr/card6"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                style="@style/MD.B"/>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="16dp"
                                android:layout_marginRight="16dp">
                                <TextView
                                    android:textStyle="bold"
                                    android:ellipsize="end"
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="@string/action_verify"
                                    android:maxLines="2"
                                    style="@style/MD.C"/>
                                <TextView
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:text="@string/action_verify_desc"
                                    style="@style/MD.D"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_db"
                            android:focusable="true"
                            android:clickable="true"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:layout_marginLeft="8dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="8dp"
                            android:checkable="true"
                            app:cardBackgroundColor="?attr/card7"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                style="@style/MD.B"/>
                            <LinearLayout
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="16dp"
                                android:layout_marginRight="16dp">
                                <TextView
                                    android:textStyle="bold"
                                    android:ellipsize="end"
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="@string/action_db"
                                    android:maxLines="2"
                                    style="@style/MD.C"/>
                                <TextView
                                    android:gravity="start"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="16dp"
                                    android:text="@string/action_db_desc"
                                    style="@style/MD.D"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="16dp"
                        android:textStyle="bold"
                        android:textColor="?attr/windowTitle"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/designby"
                        android:singleLine="true"/>
                    <TextView
                        android:textColor="?attr/windowTitle"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:id="@+id/line3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/designbydesc"/>
                    <TextView
                        android:textColor="?attr/windowTitle"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:id="@+id/line2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/build_resources"/>
                </LinearLayout>
            </LinearLayout>
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_odex"
                app:cardBackgroundColor="?attr/card4"
                style="@style/MD.A">
                <RelativeLayout style="@style/MD.B">
                    <TextView
                        android:text="@string/action_odex"
                        style="@style/MD.C"/>
                    <TextView
                        android:text="@string/action_odex_desc"
                        style="@style/MD.D"/>
                    <ImageView
                        android:src="@drawable/ic_btn_4"
                        style="@style/MD.E"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_prj"
                app:cardBackgroundColor="?attr/card3"
                style="@style/MD.A">
                <RelativeLayout style="@style/MD.B">
                    <TextView
                        android:text="@string/action_prj"
                        style="@style/MD.C"/>
                    <TextView
                        android:text="@string/action_prj_desc"
                        style="@style/MD.D"/>
                    <ImageView
                        android:src="@drawable/ic_btn_3"
                        style="@style/MD.E"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_info"
                app:cardBackgroundColor="?attr/card8"
                style="@style/MD.A">
                <RelativeLayout style="@style/MD.B">
                    <TextView
                        android:text="@string/action_info"
                        style="@style/MD.C"/>
                    <TextView
                        android:text="@string/action_info_desc"
                        style="@style/MD.D"/>
                    <ImageView
                        android:src="@drawable/ic_btn_8"
                        style="@style/MD.E"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_settings"
                app:cardBackgroundColor="?attr/card9"
                style="@style/MD.A">
                <RelativeLayout style="@style/MD.B">
                    <TextView
                        android:text="@string/action_sett"
                        style="@style/MD.C"/>
                    <TextView
                        android:text="@string/action_sett_desc"
                        style="@style/MD.D"/>
                    <ImageView
                        android:src="@drawable/ic_btn_9"
                        style="@style/MD.E"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/webButton"
                app:cardBackgroundColor="?attr/masrullcard"
                style="@style/MD.A">
                <RelativeLayout style="@style/MD.B">
                    <TextView
                        android:text="@string/webku_xml"
                        style="@style/MD.C"/>
                    <TextView
                        android:text="@string/webku_summary"
                        style="@style/MD.D"/>
                    <ImageView
                        android:src="@drawable/ic_link"
                        style="@style/MD.E"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_current"
                app:cardBackgroundColor="?attr/ytta"
                style="@style/MD.A">
                <RelativeLayout style="@style/MD.B">
                    <TextView
                        android:text="@string/current_activity"
                        style="@style/MD.C"/>
                    <TextView
                        android:text="@string/if_available_on_beta_ver"
                        style="@style/MD.D"/>
                    <ImageView
                        android:src="@drawable/ic_notification"
                        android:tint="?attr/yttaIc"
                        style="@style/MD.E"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_exit"
                app:cardBackgroundColor="?attr/card10"
                style="@style/MD.A">
                <RelativeLayout style="@style/MD.B">
                    <TextView
                        android:text="@string/action_exit"
                        style="@style/MD.C"/>
                    <TextView
                        android:text="@string/action_exit_desc"
                        style="@style/MD.D"/>
                    <ImageView
                        android:src="@drawable/ic_btn_10"
                        style="@style/MD.E"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <android.support.v7.widget.AppCompatTextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:gravity="center"
                android:paddingLeft="6dp"
                android:paddingTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/copyright"
                android:singleLine="true"
                app:fontFamily="@font/roboto_regular"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
