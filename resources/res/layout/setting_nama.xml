<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/yoi"
            android:layout_marginTop="20dp"
            android:layout_marginRight="@dimen/yoi"
            android:layout_marginBottom="@dimen/yoi">
            <TextView
                android:textSize="21dp"
                android:textStyle="bold"
                android:textColor="?attr/windowTitle"
                android:gravity="center"
                android:id="@+id/Masrulltxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp"/>
            <TextView
                android:textSize="15dp"
                android:textStyle="bold"
                android:textColor="?attr/windowTitle"
                android:gravity="center"
                android:id="@+id/Mstatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/mLayout_di"
            android:paddingTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/cilik"
            android:layout_below="@+id/linear_layout">
            <ImageView
                android:gravity="center_vertical"
                android:layout_gravity="center"
                android:id="@+id/M"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_alignParentRight="true"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/mLayout_zz"
            android:paddingTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/cilik">
            <ImageView
                android:gravity="center_vertical"
                android:layout_gravity="center"
                android:id="@+id/XwZ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_alignParentRight="true"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/mLayout_do"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginLeft="@dimen/yoi"
            android:layout_marginTop="5dp"
            android:layout_marginRight="@dimen/yoi"
            android:layout_below="@+id/mLayout_di">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/windowTitle"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="@string/nama_kamu"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:background="?attr/bottomBar"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="match_parent"
            android:layout_height="70dp">
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/mtrl_search_box"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:elevation="0dp">
                <EditText
                    android:enabled="false"
                    android:textSize="12dp"
                    android:textColor="?attr/textMedium"
                    android:id="@+id/namakamu"
                    android:background="@null"
                    android:paddingLeft="16dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:hint="@string/masukkan_nama"
                    android:maxLines="2"
                    android:layout_weight="1"/>
                <RelativeLayout
                    android:id="@+id/masrullmain"
                    android:background="@drawable/mtrl_ripple_action"
                    android:visibility="gone"
                    android:layout_width="40dp"
                    android:layout_height="40dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/md_ic_done"
                        android:tint="?attr/iconSecondary"
                        android:layout_centerInParent="true"/>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/mLayout_do"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginLeft="@dimen/yoi"
            android:layout_marginTop="5dp"
            android:layout_marginRight="@dimen/yoi"
            android:layout_below="@+id/mLayout_di">
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/windowTitle"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="@string/status_kamu"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:background="?attr/bottomBar"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="match_parent"
            android:layout_height="70dp">
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/mtrl_search_box"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:elevation="0dp">
                <EditText
                    android:enabled="false"
                    android:textSize="12dp"
                    android:textColor="?attr/textMedium"
                    android:id="@+id/status_kamu"
                    android:background="@null"
                    android:paddingLeft="16dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:hint="@string/masukkan_status"
                    android:maxLines="2"
                    android:layout_weight="1"/>
                <RelativeLayout
                    android:id="@+id/mm"
                    android:background="@drawable/mtrl_ripple_action"
                    android:visibility="gone"
                    android:layout_width="40dp"
                    android:layout_height="40dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/md_ic_done"
                        android:tint="?attr/iconSecondary"
                        android:layout_centerInParent="true"/>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/coverpic"
            android:layout_width="@dimen/cilik"
            android:layout_height="@dimen/cilik"
            android:scaleType="fitXY"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/image"
            android:layout_width="@dimen/cilik"
            android:layout_height="@dimen/cilik"
            android:scaleType="fitXY"/>
    </LinearLayout>
</ScrollView>
